# =============================================================================
# CercaChain — Docker Compose Environment Variables
# =============================================================================
# Copy to .env and fill in production values.
# This file is used by docker-compose.yml.
# =============================================================================

# --- Blockchain Node ---
API_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json
TREASURY_MNEMONIC=
ADMIN_API_KEY=
BOOTSTRAP_PEERS=

# --- Supabase (for Flutter frontend build) ---
SUPABASE_URL=https://epawttrarbrpzmdbmxyn.supabase.co
SUPABASE_ANON_KEY=

# --- API URL (used by frontend + admin panel to reach the node) ---
# In Docker network, services reference each other by container name.
# For external access, set to your public domain:
BLOCKCHAIN_API_URL=http://blockchain:8080
