# =============================================================================
# CercaChain — Blockchain Node Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Node Configuration ---
API_PORT=8080
DATABASE_PATH=./data/blockchain.db
NODE_KEY_PATH=./data/nodekey.priv
LOG_LEVEL=info
NETWORK_MODE=production

# --- Treasury ---
# CRITICAL: Generate a unique mnemonic for production!
# The default is for development ONLY and is publicly known.
TREASURY_MNEMONIC=

# --- Admin Authentication ---
# API key required for admin endpoints (/admin/*, /node/*, etc.)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# --- Supabase Hybrid Indexer ---
# Required to push on-chain state to off-chain UI
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# --- P2P Networking ---
# Comma-separated list of bootstrap peer multiaddrs
BOOTSTRAP_PEERS=
# P2P listen port
P2P_PORT=8000
