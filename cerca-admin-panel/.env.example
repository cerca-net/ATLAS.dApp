# =============================================================================
# CercaChain — Admin Panel Environment Variables (Vite)
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Vite requires VITE_ prefix for client-side env vars.
# =============================================================================

# --- Node API URL ---
# The URL of the ATLAS blockchain node API
VITE_NODE_URL=http://localhost:8080

# --- Admin API Key ---
# Must match ADMIN_API_KEY set on the blockchain node
# Leave empty for local dev (admin endpoints will be unprotected)
VITE_ADMIN_API_KEY=
