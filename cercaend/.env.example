# =============================================================================
# CercaChain — Flutter App Build-Time Environment Variables
# =============================================================================
# These values are injected at build time using --dart-define flags.
# This file is documentation only — Dart doesn't read .env files.
#
# Build command:
#   flutter run \
#     --dart-define=SUPABASE_URL=https://xxx.supabase.co \
#     --dart-define=SUPABASE_ANON_KEY=eyJ... \
#     --dart-define=BLOCKCHAIN_API_URL=https://api.cercachain.io
#
# Or for web builds:
#   flutter build web \
#     --dart-define=SUPABASE_URL=https://xxx.supabase.co \
#     --dart-define=SUPABASE_ANON_KEY=eyJ... \
#     --dart-define=BLOCKCHAIN_API_URL=https://api.cercachain.io
# =============================================================================

